---
layout: base.njk
permalink: /contact/
pageKey: contact
bodyAttr: 'data-audience="dj"'
---
{% import "macros.njk" as m %}
{% set d = pages.contact %}

<section class="pagehero theme-dark">
  <div class="hero__grid"></div>
  <div class="pagehero__glow"></div>
  <div class="container">
    <h1 class="display" data-hero style="--d:120">{{ d.hero.headline | nl2br | safe }}</h1>
    <p class="lede" data-hero style="--d:260">{{ d.hero.lede }}</p>
  </div>
</section>

<section class="section theme-dark" style="padding-top:clamp(1.5rem,3vw,2.5rem)">
  <div class="container">
    <div class="contact-wrap">
      <!-- Aside -->
      <aside class="contact-aside" data-reveal="left">
        <div class="card">
          <h3 style="font-size:1.3rem;margin-bottom:.4rem">{{ d.aside.heading }}</h3>
          <p style="color:var(--muted);margin-bottom:.4rem">{{ d.aside.subtext }}</p>
          <div class="channel">
            <span class="ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.6"/></svg></span>
            <span><span class="k">Email</span><br><a class="v txtlink" href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></span>
          </div>
          <div class="channel">
            <span class="ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg></span>
            <span><span class="k">Instagram</span><br><a class="v txtlink" href="{{ site.contact.instagram.url }}" target="_blank" rel="noopener">{{ site.contact.instagram.label }}</a></span>
          </div>
        </div>
      </aside>

      <!-- Form -->
      <div data-reveal="right">
        <div class="toggle" role="tablist" aria-label="I am a…">
          <span class="toggle__pill"></span>
          <button class="is-active" data-role="dj" role="tab">I’m a DJ</button>
          <button data-role="venue" role="tab">I run a venue</button>
        </div>

        <form class="form" novalidate>
          <div class="field row2">
            <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" placeholder="your name" required></div>
            <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" placeholder="you@email.com" required></div>
          </div>
          <div class="field row2">
            <div class="field"><label for="phone">Phone <span style="text-transform:none;color:var(--faint)">(optional)</span></label><input id="phone" name="phone" type="tel" placeholder="04xx xxx xxx"></div>
            <div class="field">
              <label for="genre">Genre / style</label>
              <select id="genre" name="genre">{% for g in site.genres %}<option>{{ g }}</option>{% endfor %}<option>other</option></select>
            </div>
          </div>
          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="where you play, your style, links to a mix or soundcloud…" required></textarea>
          </div>
          <div class="form__note">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ d.form.note }}
          </div>
          <button class="btn btn--lg btn--block" type="submit" data-magnetic="0.18">{{ d.form.submitLabel }} {{ m.arrow(16) }}</button>
          <div class="form__success" role="status">{{ d.form.success }} ↗</div>
        </form>
      </div>
    </div>
  </div>
</section>
